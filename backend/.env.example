# Copy to .env and fill in.
GEMINI_API_KEY=your-key-here
# Optional — override default model.
# Default is a Gemma model (higher free-tier quota, no responseMimeType support).
# For Gemma 4 31B, paste the exact catalog id, e.g. "gemma-4-31b-it".
# For Gemini, use e.g. "gemini-2.0-flash" or "gemini-2.0-flash-lite".
GEMINI_MODEL=gemma-3-27b-it
# Optional — if tesseract / poppler are not on PATH
# TESSERACT_CMD=/opt/homebrew/bin/tesseract
# POPPLER_PATH=/opt/homebrew/bin
# Optional — comma-separated CORS origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
